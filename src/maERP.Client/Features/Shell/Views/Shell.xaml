<UserControl x:Class="maERP.Client.Features.Shell.Views.Shell"
     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
     xmlns:local="using:maERP.Client.Features.Shell.Views"
     xmlns:models="using:maERP.Client.Features.Shell.Models"
     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
     xmlns:utu="using:Uno.Toolkit.UI"
     xmlns:uen="using:Uno.Extensions.Navigation.UI"
     mc:Ignorable="d"
     d:DesignHeight="800"
     d:DesignWidth="1280">

  <UserControl.Resources>
    <!-- Sidebar nav item button style -->
    <Style x:Key="SidebarNavItemStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="12,0,12,0" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Margin" Value="8,1,8,1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Foreground" Value="{ThemeResource OnSurfaceBrush}" />
    </Style>

    <!-- Sidebar section header -->
    <Style x:Key="SidebarSectionHeaderStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
      <Setter Property="Margin" Value="20,18,12,6" />
      <Setter Property="CharacterSpacing" Value="60" />
    </Style>

    <!-- Sidebar collapsible group header button -->
    <Style x:Key="SidebarGroupHeaderStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="20,18,12,6" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
  </UserControl.Resources>

  <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!-- VisualStateManager for responsive breakpoints -->
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup>
        <!-- Narrow: Mobile phones (< 700px) -->
        <VisualState x:Name="Narrow">
          <VisualState.Setters>
            <Setter Target="TabBarNav.Visibility" Value="Visible" />
            <Setter Target="Sidebar.Visibility" Value="Collapsed" />
            <Setter Target="ContentHeader.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>

        <!-- Normal: Tablets (700px - 999px) -->
        <VisualState x:Name="Normal">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="700" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="TabBarNav.Visibility" Value="Collapsed" />
            <Setter Target="Sidebar.Visibility" Value="Visible" />
            <Setter Target="Sidebar.Width" Value="220" />
            <Setter Target="ContentHeader.Visibility" Value="Visible" />
          </VisualState.Setters>
        </VisualState>

        <!-- Wide: Desktop (>= 1000px) -->
        <VisualState x:Name="Wide">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1000" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="TabBarNav.Visibility" Value="Collapsed" />
            <Setter Target="Sidebar.Visibility" Value="Visible" />
            <Setter Target="Sidebar.Width" Value="260" />
            <Setter Target="ContentHeader.Visibility" Value="Visible" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- ====================== SIDEBAR ====================== -->
    <Grid x:Name="Sidebar"
          Grid.Column="0"
          Width="260"
          Background="{ThemeResource SurfaceVariantBrush}"
          BorderBrush="{ThemeResource OutlineVariantBrush}"
          BorderThickness="0,0,1,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Brand + Tenant Switcher -->
      <Grid Grid.Row="0"
            Height="48"
            Padding="12,0,12,0"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="0,0,0,1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Image Grid.Column="0"
               Source="ms-appx:///Assets/Icons/icon.svg"
               Width="28"
               Height="28"
               Stretch="Uniform"
               VerticalAlignment="Center" />

        <!-- Multiple Tenants: DropDown -->
        <DropDownButton x:Name="TenantSwitcher"
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="6,0"
                        Visibility="Collapsed">
          <TextBlock x:Name="TenantSwitcherText"
                     Style="{StaticResource BodyMedium}"
                     FontWeight="SemiBold"
                     Foreground="{ThemeResource OnSurfaceBrush}"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
          <DropDownButton.Flyout>
            <MenuFlyout x:Name="TenantMenuFlyout"
                        Placement="BottomEdgeAlignedLeft" />
          </DropDownButton.Flyout>
        </DropDownButton>

        <!-- Single or No Tenant: Text -->
        <TextBlock x:Name="TenantName"
                   Grid.Column="1"
                   Style="{StaticResource BodyMedium}"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource OnSurfaceBrush}"
                   VerticalAlignment="Center"
                   Margin="10,0,0,0"
                   TextTrimming="CharacterEllipsis" />
      </Grid>

      <!-- Quick Search (optical only) -->
      <Grid Grid.Row="1"
            Padding="12,12,12,4">
        <Border Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource OutlineVariantBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Height="32">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon Grid.Column="0"
                      Glyph="&#xE721;"
                      FontSize="12"
                      Foreground="{ThemeResource OnSurfaceVariantBrush}"
                      Margin="10,0,0,0"
                      VerticalAlignment="Center" />

            <TextBlock Grid.Column="1"
                       x:Uid="Shell.Search.Placeholder"
                       Style="{StaticResource BodySmall}"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center" />

            <Border Grid.Column="2"
                    Background="{ThemeResource SurfaceVariantBrush}"
                    BorderBrush="{ThemeResource OutlineVariantBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="5,1"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center">
              <TextBlock Text="⌘K"
                         FontSize="10"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}" />
            </Border>
          </Grid>
        </Border>
      </Grid>

      <!-- Navigation Groups -->
      <ScrollViewer Grid.Row="2"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="NavItemsPanel"
                    Padding="0,8,0,12">

          <!-- Dashboard (no group) -->
          <Button x:Name="NavItemDashboard"
                  Style="{StaticResource SidebarNavItemStyle}"
                  Tag="Dashboard"
                  Click="OnNavItemClick">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <FontIcon Glyph="&#xE80F;" FontSize="16" />
              <TextBlock x:Uid="Shell.NavItem.Dashboard"
                         Style="{StaticResource BodyMedium}"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <!-- VERKAUF -->
          <Button x:Name="GroupVerkaufHeader"
                  Style="{StaticResource SidebarGroupHeaderStyle}"
                  Tag="GroupVerkaufContent"
                  Click="OnGroupHeaderClick">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Uid="Shell.NavGroup.Verkauf"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         CharacterSpacing="60"
                         VerticalAlignment="Center" />
              <FontIcon x:Name="GroupVerkaufChevron"
                        Grid.Column="1"
                        Glyph="&#xE70D;"
                        FontSize="10"
                        Foreground="{ThemeResource OnSurfaceVariantBrush}"
                        VerticalAlignment="Center" />
            </Grid>
          </Button>
          <StackPanel x:Name="GroupVerkaufContent">
            <Button x:Name="NavItemOrders"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Orders"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE7BF;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Orders"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemInvoices"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Invoices"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE9F9;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Invoices"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemSalesChannels"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="SalesChannels"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE8A7;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.SalesChannels"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <!-- Dynamic SalesChannel sub-items -->
            <ItemsControl x:Name="SalesChannelSubItemsContainer" />
          </StackPanel>

          <!-- STAMMDATEN -->
          <Button x:Name="GroupStammdatenHeader"
                  Style="{StaticResource SidebarGroupHeaderStyle}"
                  Tag="GroupStammdatenContent"
                  Click="OnGroupHeaderClick">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Uid="Shell.NavGroup.Stammdaten"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         CharacterSpacing="60"
                         VerticalAlignment="Center" />
              <FontIcon x:Name="GroupStammdatenChevron"
                        Grid.Column="1"
                        Glyph="&#xE70D;"
                        FontSize="10"
                        Foreground="{ThemeResource OnSurfaceVariantBrush}"
                        VerticalAlignment="Center" />
            </Grid>
          </Button>
          <StackPanel x:Name="GroupStammdatenContent">
            <Button x:Name="NavItemCustomers"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Customers"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE716;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Customers"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemProducts"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Products"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE7BF;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Products"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemManufacturers"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Manufacturers"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE8FD;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Manufacturers"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- EINSTELLUNGEN -->
          <Button x:Name="GroupEinstellungenHeader"
                  Style="{StaticResource SidebarGroupHeaderStyle}"
                  Tag="GroupEinstellungenContent"
                  Click="OnGroupHeaderClick">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Uid="Shell.NavGroup.Einstellungen"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         CharacterSpacing="60"
                         VerticalAlignment="Center" />
              <FontIcon x:Name="GroupEinstellungenChevron"
                        Grid.Column="1"
                        Glyph="&#xE76C;"
                        FontSize="10"
                        Foreground="{ThemeResource OnSurfaceVariantBrush}"
                        VerticalAlignment="Center" />
            </Grid>
          </Button>
          <StackPanel x:Name="GroupEinstellungenContent" Visibility="Collapsed">
            <Button x:Name="NavItemTaxClasses"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="TaxClasses"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE912;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.TaxClasses"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemWarehouses"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="Warehouses"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE913;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.Warehouses"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemAiModels"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="AiModels"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE99A;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.AiModels"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="NavItemAiPrompts"
                    Style="{StaticResource SidebarNavItemStyle}"
                    Tag="AiPrompts"
                    Click="OnNavItemClick">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE8BD;" FontSize="16" />
                <TextBlock x:Uid="Shell.NavItem.AiPrompts"
                           Style="{StaticResource BodyMedium}"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- SUPERADMIN -->
          <StackPanel x:Name="GroupSuperadminPanel" Visibility="Collapsed">
            <Button x:Name="GroupSuperadminHeader"
                    Style="{StaticResource SidebarGroupHeaderStyle}"
                    Tag="GroupSuperadminContent"
                    Click="OnGroupHeaderClick">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Uid="Shell.NavGroup.Superadmin"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           CharacterSpacing="60"
                           VerticalAlignment="Center" />
                <FontIcon x:Name="GroupSuperadminChevron"
                          Grid.Column="1"
                          Glyph="&#xE76C;"
                          FontSize="10"
                          Foreground="{ThemeResource OnSurfaceVariantBrush}"
                          VerticalAlignment="Center" />
              </Grid>
            </Button>
            <StackPanel x:Name="GroupSuperadminContent" Visibility="Collapsed">
              <Button x:Name="NavItemSuperadminTenants"
                      Style="{StaticResource SidebarNavItemStyle}"
                      Tag="SuperadminTenants"
                      Click="OnNavItemClick">
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <FontIcon Glyph="&#xE7EE;" FontSize="16" />
                  <TextBlock x:Uid="Shell.NavItem.AllTenants"
                             Style="{StaticResource BodyMedium}"
                             VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

    </Grid>

    <!-- ====================== CONTENT AREA ====================== -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- Minimal top bar (user menu on the right) -->
      <Grid x:Name="ContentHeader"
            Grid.Row="0"
            Height="48"
            Background="{ThemeResource BackgroundBrush}"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Spacing="4">
          <Button x:Name="UserMenuButton"
                  Style="{StaticResource TextButtonStyle}"
                  Padding="8,6"
                  CornerRadius="8"
                  Foreground="{ThemeResource OnSurfaceBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE77B;"
                        FontSize="16"
                        Foreground="{ThemeResource OnSurfaceBrush}" />
              <TextBlock x:Name="UserMenuText"
                         x:Uid="Shell.UserMenu.Text"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <Button.Flyout>
              <MenuFlyout Placement="BottomEdgeAlignedRight">
                <MenuFlyoutItem x:Name="MenuItemMyAccount"
                                x:Uid="Shell.UserMenu.MyAccount"
                                Tag="UserProfile"
                                Click="OnNavItemClick">
                  <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE77B;" />
                  </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="MenuItemTenants"
                                x:Uid="Shell.UserMenu.Tenants"
                                Tag="Tenants"
                                Click="OnNavItemClick">
                  <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE902;" />
                  </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutSeparator />
                <MenuFlyoutItem x:Name="MenuItemDarkModeCompat"
                                x:Uid="Shell.UserMenu.DarkMode"
                                Click="OnDarkModeToggle">
                  <MenuFlyoutItem.Icon>
                    <FontIcon x:Name="DarkModeIcon" Glyph="&#xE793;" />
                  </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem x:Name="MenuItemLogout"
                                x:Uid="Shell.UserMenu.Logout"
                                Click="OnLogoutClick">
                  <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE7E8;" />
                  </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Main Content Area -->
      <Grid Grid.Row="1">
        <utu:ExtendedSplashScreen x:Name="Splash"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Stretch">
          <utu:ExtendedSplashScreen.LoadingContentTemplate>
            <DataTemplate>
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="2*" />
                  <RowDefinition />
                </Grid.RowDefinitions>
                <ProgressRing IsActive="True"
                              Grid.Row="1"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Height="100"
                              Width="100" />
              </Grid>
            </DataTemplate>
          </utu:ExtendedSplashScreen.LoadingContentTemplate>
        </utu:ExtendedSplashScreen>
      </Grid>

      <!-- TabBar for Mobile (Bottom Navigation) -->
      <utu:TabBar x:Name="TabBarNav"
                  Grid.Row="2"
                  Visibility="Collapsed"
                  VerticalAlignment="Bottom"
                  Style="{StaticResource MaterialBottomTabBarStyle}">
        <utu:TabBar.Items>
          <utu:TabBarItem x:Name="TabItemDashboard"
                          Style="{StaticResource MaterialBottomTabBarItemStyle}"
                          x:Uid="Shell.NavItem.Dashboard"
                          Tag="Main">
            <utu:TabBarItem.Icon>
              <FontIcon Glyph="&#xE80F;" />
            </utu:TabBarItem.Icon>
          </utu:TabBarItem>

          <utu:TabBarItem x:Name="TabItemCustomers"
                          Style="{StaticResource MaterialBottomTabBarItemStyle}"
                          x:Uid="Shell.NavItem.Customers"
                          Tag="Customers">
            <utu:TabBarItem.Icon>
              <FontIcon Glyph="&#xE716;" />
            </utu:TabBarItem.Icon>
          </utu:TabBarItem>

          <utu:TabBarItem x:Name="TabItemOrders"
                          Style="{StaticResource MaterialBottomTabBarItemStyle}"
                          x:Uid="Shell.NavItem.Orders"
                          Tag="Orders">
            <utu:TabBarItem.Icon>
              <FontIcon Glyph="&#xE7BF;" />
            </utu:TabBarItem.Icon>
          </utu:TabBarItem>

          <utu:TabBarItem x:Name="TabItemSettings"
                          Style="{StaticResource MaterialBottomTabBarItemStyle}"
                          x:Uid="Shell.NavItem.Settings"
                          Tag="Settings">
            <utu:TabBarItem.Icon>
              <FontIcon Glyph="&#xE713;" />
            </utu:TabBarItem.Icon>
          </utu:TabBarItem>

          <utu:TabBarItem x:Name="TabItemLogout"
                          Style="{StaticResource MaterialBottomTabBarItemStyle}"
                          x:Uid="Shell.NavItem.Logout"
                          Tag="Logout">
            <utu:TabBarItem.Icon>
              <FontIcon Glyph="&#xE7E8;" />
            </utu:TabBarItem.Icon>
          </utu:TabBarItem>
        </utu:TabBar.Items>
      </utu:TabBar>
    </Grid>

    <!-- Login Overlay (shown when NOT authenticated) - spans both columns -->
    <Grid x:Name="LoginOverlay"
          Grid.Column="0"
          Grid.ColumnSpan="2"
          Visibility="Visible"
          Background="{ThemeResource SurfaceVariantBrush}">
      <Grid.RowDefinitions>
        <RowDefinition Height="48" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Brand bar (mirrors Sidebar brand row + ContentHeader) -->
      <Grid Grid.Row="0"
            Background="{ThemeResource BackgroundBrush}"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,0,12,0">
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Image Source="ms-appx:///Assets/Icons/icon.svg"
                 Width="28"
                 Height="28"
                 Stretch="Uniform"
                 VerticalAlignment="Center" />
          <TextBlock Text="maERP"
                     Style="{StaticResource BodyMedium}"
                     FontWeight="SemiBold"
                     Foreground="{ThemeResource OnSurfaceBrush}"
                     VerticalAlignment="Center"
                     Margin="10,0,0,0" />
        </StackPanel>
      </Grid>

      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
        <StackPanel Spacing="24"
                    Padding="24"
                    MaxWidth="500"
                    HorizontalAlignment="Center">

          <!-- Welcome Header -->
          <StackPanel Spacing="8"
                      HorizontalAlignment="Center">
            <TextBlock x:Uid="Shell.Login.Title"
                       Style="{StaticResource HeadlineSmall}"
                       Foreground="{ThemeResource OnSurfaceBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
            <TextBlock x:Uid="Shell.Login.Subtitle"
                       Style="{StaticResource BodyLarge}"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
          </StackPanel>

          <!-- Error Message Banner -->
          <Border x:Name="LoginErrorBanner"
                  Background="{ThemeResource ErrorContainerBrush}"
                  CornerRadius="8"
                  Padding="16"
                  Visibility="Collapsed">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <FontIcon Grid.Column="0"
                        Glyph="&#xE783;"
                        FontSize="20"
                        Foreground="{ThemeResource OnErrorContainerBrush}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center" />
              <TextBlock x:Name="LoginErrorText"
                         Grid.Column="1"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnErrorContainerBrush}"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center" />
            </Grid>
          </Border>

          <!-- Login Form Card -->
          <Border Background="{ThemeResource SurfaceBrush}"
                  CornerRadius="12"
                  Translation="0,0,8">
            <Border.Shadow>
              <ThemeShadow />
            </Border.Shadow>
            <StackPanel Spacing="0">
              <Grid Padding="16,16,16,8">
                <StackPanel Orientation="Horizontal">
                  <FontIcon Glyph="&#xE77B;"
                            FontSize="20"
                            Foreground="{ThemeResource PrimaryBrush}"
                            Margin="0,0,12,0" />
                  <TextBlock x:Uid="Shell.Login.FormTitle"
                             Style="{StaticResource TitleMedium}"
                             Foreground="{ThemeResource OnSurfaceBrush}" />
                </StackPanel>
              </Grid>

              <StackPanel Padding="16,0,16,16"
                          Spacing="16">
                <TextBox x:Name="LoginServerUrl"
                         x:Uid="Shell.Login.ServerUrl"
                         AutomationProperties.Name="Server URL"
                         LostFocus="LoginServerUrl_LostFocus" />

                <TextBox x:Name="LoginEmail"
                         x:Uid="Shell.Login.Email"
                         InputScope="EmailSmtpAddress"
                         AutomationProperties.Name="Email" />

                <PasswordBox x:Name="LoginPassword"
                             x:Uid="Shell.Login.Password"
                             AutomationProperties.Name="Password" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Action Buttons -->
          <StackPanel Spacing="16">
            <ProgressRing x:Name="LoginProgress"
                          IsActive="False"
                          Width="24"
                          Height="24"
                          Visibility="Collapsed"
                          HorizontalAlignment="Center" />
            <Button x:Name="LoginButton"
                    x:Uid="Shell.Login.LoginButton"
                    Style="{StaticResource FilledButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Click="LoginButton_Click" />
            <TextBlock x:Name="RegisterLink"
                       Visibility="Collapsed"
                       HorizontalAlignment="Center"
                       Style="{StaticResource BodyMedium}">
              <Hyperlink Click="RegisterLink_Click">
                <Run x:Uid="Shell.Login.RegisterLink" />
              </Hyperlink>
            </TextBlock>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- Registration Overlay (shown when user clicks the register link) - spans both columns -->
    <Grid x:Name="RegistrationOverlay"
          Grid.Column="0"
          Grid.ColumnSpan="2"
          Visibility="Collapsed"
          Background="{ThemeResource SurfaceVariantBrush}">
      <Grid.RowDefinitions>
        <RowDefinition Height="48" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Brand bar (mirrors Sidebar brand row + ContentHeader) -->
      <Grid Grid.Row="0"
            Background="{ThemeResource BackgroundBrush}"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,0,12,0">
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Image Source="ms-appx:///Assets/Icons/icon.svg"
                 Width="28"
                 Height="28"
                 Stretch="Uniform"
                 VerticalAlignment="Center" />
          <TextBlock Text="maERP"
                     Style="{StaticResource BodyMedium}"
                     FontWeight="SemiBold"
                     Foreground="{ThemeResource OnSurfaceBrush}"
                     VerticalAlignment="Center"
                     Margin="10,0,0,0" />
        </StackPanel>
      </Grid>

      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
        <StackPanel Spacing="24"
                    Padding="24"
                    MaxWidth="500"
                    HorizontalAlignment="Center">

          <StackPanel Spacing="8"
                      HorizontalAlignment="Center">
            <TextBlock x:Uid="Shell.Register.Title"
                       Style="{StaticResource HeadlineSmall}"
                       Foreground="{ThemeResource OnSurfaceBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
            <TextBlock x:Uid="Shell.Register.Subtitle"
                       Style="{StaticResource BodyLarge}"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Border x:Name="RegisterErrorBanner"
                  Background="{ThemeResource ErrorContainerBrush}"
                  CornerRadius="8"
                  Padding="16"
                  Visibility="Collapsed">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <FontIcon Grid.Column="0"
                        Glyph="&#xE783;"
                        FontSize="20"
                        Foreground="{ThemeResource OnErrorContainerBrush}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center" />
              <TextBlock x:Name="RegisterErrorText"
                         Grid.Column="1"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnErrorContainerBrush}"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center" />
            </Grid>
          </Border>

          <Border Background="{ThemeResource SurfaceBrush}"
                  CornerRadius="12"
                  Translation="0,0,8">
            <Border.Shadow>
              <ThemeShadow />
            </Border.Shadow>
            <StackPanel Spacing="0">
              <Grid Padding="16,16,16,8">
                <StackPanel Orientation="Horizontal">
                  <FontIcon Glyph="&#xE8FA;"
                            FontSize="20"
                            Foreground="{ThemeResource PrimaryBrush}"
                            Margin="0,0,12,0" />
                  <TextBlock x:Uid="Shell.Register.FormTitle"
                             Style="{StaticResource TitleMedium}"
                             Foreground="{ThemeResource OnSurfaceBrush}" />
                </StackPanel>
              </Grid>

              <StackPanel Padding="16,0,16,16"
                          Spacing="16">
                <TextBox x:Name="RegisterFirstname"
                         x:Uid="Shell.Register.Firstname" />

                <TextBox x:Name="RegisterLastname"
                         x:Uid="Shell.Register.Lastname" />

                <TextBox x:Name="RegisterEmail"
                         x:Uid="Shell.Register.Email"
                         InputScope="EmailSmtpAddress" />

                <PasswordBox x:Name="RegisterPassword"
                             x:Uid="Shell.Register.Password" />

                <PasswordBox x:Name="RegisterPasswordConfirm"
                             x:Uid="Shell.Register.PasswordConfirm" />
              </StackPanel>
            </StackPanel>
          </Border>

          <StackPanel Spacing="16">
            <ProgressRing x:Name="RegisterProgress"
                          IsActive="False"
                          Width="24"
                          Height="24"
                          Visibility="Collapsed"
                          HorizontalAlignment="Center" />
            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Button x:Name="RegisterCancelButton"
                      Grid.Column="0"
                      x:Uid="Shell.Register.Cancel"
                      Style="{StaticResource OutlinedButtonStyle}"
                      HorizontalAlignment="Stretch"
                      Click="RegisterCancel_Click" />
              <Button x:Name="RegisterSubmitButton"
                      Grid.Column="1"
                      x:Uid="Shell.Register.Submit"
                      Style="{StaticResource FilledButtonStyle}"
                      HorizontalAlignment="Stretch"
                      Click="RegisterSubmit_Click" />
            </Grid>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- First Tenant Creation Overlay - spans both columns -->
    <Grid x:Name="FirstTenantOverlay"
          Grid.Column="0"
          Grid.ColumnSpan="2"
          Visibility="Collapsed"
          Background="{ThemeResource SurfaceVariantBrush}">
      <Grid.RowDefinitions>
        <RowDefinition Height="48" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Brand bar (mirrors Sidebar brand row + ContentHeader) -->
      <Grid Grid.Row="0"
            Background="{ThemeResource BackgroundBrush}"
            BorderBrush="{ThemeResource OutlineVariantBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,0,12,0">
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Image Source="ms-appx:///Assets/Icons/icon.svg"
                 Width="28"
                 Height="28"
                 Stretch="Uniform"
                 VerticalAlignment="Center" />
          <TextBlock Text="maERP"
                     Style="{StaticResource BodyMedium}"
                     FontWeight="SemiBold"
                     Foreground="{ThemeResource OnSurfaceBrush}"
                     VerticalAlignment="Center"
                     Margin="10,0,0,0" />
        </StackPanel>
      </Grid>

      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
        <StackPanel Spacing="24"
                    Padding="24"
                    MaxWidth="500"
                    HorizontalAlignment="Center">

          <StackPanel Spacing="8"
                      HorizontalAlignment="Center">
            <TextBlock x:Uid="Shell.FirstTenant.Title"
                       Style="{StaticResource HeadlineSmall}"
                       Foreground="{ThemeResource OnSurfaceBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
            <TextBlock x:Uid="Shell.FirstTenant.Subtitle"
                       Style="{StaticResource BodyLarge}"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Border x:Name="FirstTenantErrorBanner"
                  Background="{ThemeResource ErrorContainerBrush}"
                  CornerRadius="8"
                  Padding="16"
                  Visibility="Collapsed">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <FontIcon Grid.Column="0"
                        Glyph="&#xE783;"
                        FontSize="20"
                        Foreground="{ThemeResource OnErrorContainerBrush}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center" />
              <TextBlock x:Name="FirstTenantErrorText"
                         Grid.Column="1"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnErrorContainerBrush}"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center" />
            </Grid>
          </Border>

          <Border Background="{ThemeResource SurfaceBrush}"
                  CornerRadius="12"
                  Translation="0,0,8">
            <Border.Shadow>
              <ThemeShadow />
            </Border.Shadow>
            <StackPanel Spacing="0">
              <Grid Padding="16,16,16,8">
                <StackPanel Orientation="Horizontal">
                  <FontIcon Glyph="&#xE902;"
                            FontSize="20"
                            Foreground="{ThemeResource PrimaryBrush}"
                            Margin="0,0,12,0" />
                  <TextBlock x:Uid="Shell.FirstTenant.FormTitle"
                             Style="{StaticResource TitleMedium}"
                             Foreground="{ThemeResource OnSurfaceBrush}" />
                </StackPanel>
              </Grid>

              <StackPanel Padding="16,0,16,16"
                          Spacing="16">
                <TextBox x:Name="FirstTenantName"
                         x:Uid="TenantEditPage.Field.Name"
                         TextChanged="FirstTenantName_TextChanged" />

                <TextBox x:Name="FirstTenantDescription"
                         x:Uid="TenantEditPage.Field.Description"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="80"
                         MaxHeight="120" />

                <TextBlock x:Uid="TenantEditPage.RequiredFieldsNote"
                           Style="{StaticResource LabelSmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
              </StackPanel>
            </StackPanel>
          </Border>

          <StackPanel Spacing="16">
            <ProgressRing x:Name="FirstTenantProgress"
                          IsActive="False"
                          Width="24"
                          Height="24"
                          Visibility="Collapsed"
                          HorizontalAlignment="Center" />
            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Button x:Name="FirstTenantCancelButton"
                      Grid.Column="0"
                      x:Uid="Shell.FirstTenant.Cancel"
                      Style="{StaticResource OutlinedButtonStyle}"
                      HorizontalAlignment="Stretch"
                      Click="FirstTenantCancel_Click" />
              <Button x:Name="FirstTenantSaveButton"
                      Grid.Column="1"
                      x:Uid="Shell.FirstTenant.Create"
                      Style="{StaticResource FilledButtonStyle}"
                      HorizontalAlignment="Stretch"
                      IsEnabled="False"
                      Click="FirstTenantSave_Click" />
            </Grid>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
