<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">

  <!-- Compact Input Controls Styling -->
  <!-- Reduces padding and height for TextBox and ComboBox controls -->

  <!-- TextBox - Outlined Style (Default) -->
  <Thickness x:Key="OutlinedTextBoxPadding">12,0</Thickness>
  <system:Double x:Key="OutlinedTextBoxMinHeight">40</system:Double>

  <!-- TextBox - Filled Style -->
  <Thickness x:Key="FilledTextBoxPadding">12,0</Thickness>
  <system:Double x:Key="FilledTextBoxMinHeight">40</system:Double>

  <!-- PasswordBox - Outlined Style (Default) -->
  <Thickness x:Key="OutlinedPasswordBoxPadding">12,0,8,0</Thickness>
  <system:Double x:Key="OutlinedPasswordBoxMinHeight">40</system:Double>

  <!-- PasswordBox - Filled Style -->
  <Thickness x:Key="FilledPasswordBoxPadding">12,0,8,0</Thickness>
  <system:Double x:Key="FilledPasswordBoxMinHeight">40</system:Double>

  <!-- ComboBox -->
  <Thickness x:Key="ComboBoxPadding">12,0</Thickness>
  <system:Double x:Key="ComboBoxMinHeight">40</system:Double>
  <system:Double x:Key="ComboBoxHeight">36</system:Double>

  <!-- Compact ComboBox style for pagination "page size" pickers -->
  <Style x:Key="PageSizeComboBoxStyle" TargetType="ComboBox">
    <Setter Property="Height" Value="32" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="MinWidth" Value="72" />
    <Setter Property="Padding" Value="10,0" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

</ResourceDictionary>
