<!-- Cloudflare-inspired blue palette (manually maintained - do not regenerate from zip) -->
<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <Color x:Key="PrimaryColor">#2563EB</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#DBEAFE</Color>
      <Color x:Key="OnPrimaryContainerColor">#0C1E3D</Color>
      <Color x:Key="SecondaryColor">#475569</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#E2E8F0</Color>
      <Color x:Key="OnSecondaryContainerColor">#0F172A</Color>
      <Color x:Key="TertiaryColor">#0EA5E9</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#E0F2FE</Color>
      <Color x:Key="OnTertiaryContainerColor">#082F49</Color>
      <Color x:Key="ErrorColor">#DC2626</Color>
      <Color x:Key="ErrorContainerColor">#FEE2E2</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#7F1D1D</Color>
      <Color x:Key="BackgroundColor">#FFFFFF</Color>
      <Color x:Key="OnBackgroundColor">#111827</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#111827</Color>
      <Color x:Key="SurfaceVariantColor">#F3F4F6</Color>
      <Color x:Key="OnSurfaceVariantColor">#6B7280</Color>
      <Color x:Key="OutlineColor">#9CA3AF</Color>
      <Color x:Key="OnSurfaceInverseColor">#F9FAFB</Color>
      <Color x:Key="SurfaceInverseColor">#1F2937</Color>
      <Color x:Key="PrimaryInverseColor">#93C5FD</Color>
      <Color x:Key="SurfaceTintColor">#2563EB</Color>
      <Color x:Key="OutlineVariantColor">#E5E7EB</Color>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <Color x:Key="PrimaryColor">#60A5FA</Color>
      <Color x:Key="OnPrimaryColor">#0C1E3D</Color>
      <Color x:Key="PrimaryContainerColor">#1E40AF</Color>
      <Color x:Key="OnPrimaryContainerColor">#DBEAFE</Color>
      <Color x:Key="SecondaryColor">#CBD5E1</Color>
      <Color x:Key="OnSecondaryColor">#1E293B</Color>
      <Color x:Key="SecondaryContainerColor">#334155</Color>
      <Color x:Key="OnSecondaryContainerColor">#E2E8F0</Color>
      <Color x:Key="TertiaryColor">#7DD3FC</Color>
      <Color x:Key="OnTertiaryColor">#082F49</Color>
      <Color x:Key="TertiaryContainerColor">#075985</Color>
      <Color x:Key="OnTertiaryContainerColor">#E0F2FE</Color>
      <Color x:Key="ErrorColor">#FCA5A5</Color>
      <Color x:Key="ErrorContainerColor">#7F1D1D</Color>
      <Color x:Key="OnErrorColor">#450A0A</Color>
      <Color x:Key="OnErrorContainerColor">#FEE2E2</Color>
      <Color x:Key="BackgroundColor">#0F172A</Color>
      <Color x:Key="OnBackgroundColor">#E2E8F0</Color>
      <Color x:Key="SurfaceColor">#1E293B</Color>
      <Color x:Key="OnSurfaceColor">#E2E8F0</Color>
      <Color x:Key="SurfaceVariantColor">#334155</Color>
      <Color x:Key="OnSurfaceVariantColor">#94A3B8</Color>
      <Color x:Key="OutlineColor">#64748B</Color>
      <Color x:Key="OnSurfaceInverseColor">#0F172A</Color>
      <Color x:Key="SurfaceInverseColor">#E2E8F0</Color>
      <Color x:Key="PrimaryInverseColor">#1E40AF</Color>
      <Color x:Key="SurfaceTintColor">#60A5FA</Color>
      <Color x:Key="OutlineVariantColor">#475569</Color>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
